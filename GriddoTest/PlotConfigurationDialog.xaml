<Window
    x:Class="GriddoTest.PlotConfigurationDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Plot configurator"
    Width="960"
    Height="620"
    MinWidth="760"
    MinHeight="520"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterOwner">
    <DockPanel>
        <Border
            DockPanel.Dock="Bottom"
            Padding="10,8"
            Background="#FFF0F0F0"
            BorderBrush="#FFD0D0D0"
            BorderThickness="0,1,0,0">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button
                    Width="88"
                    Margin="0,0,8,0"
                    Click="Apply_Click"
                    Content="Apply" />
                <Button
                    Width="88"
                    Margin="0,0,8,0"
                    Click="Ok_Click"
                    Content="OK"
                    IsDefault="True" />
                <Button
                    Width="88"
                    Content="Cancel"
                    IsCancel="True" />
            </StackPanel>
        </Border>
        <TabControl Margin="8">
            <TabItem Header="Title and labels">
                <Grid Margin="8,6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Margin="0,0,0,6" FontWeight="SemiBold" Text="Title (multi-line supported)" />
                    <TextBox
                        x:Name="TitleText"
                        Grid.Row="1"
                        MinHeight="120"
                        AcceptsReturn="True"
                        VerticalScrollBarVisibility="Auto"
                        TextWrapping="Wrap" />
                    <GroupBox Grid.Row="2" Margin="0,10,0,0" Header="Label" Padding="8">
                        <TextBox
                            x:Name="LabelText"
                            MinHeight="24"
                            TextWrapping="Wrap"
                            ToolTip="Optional subtitle shown under the title" />
                    </GroupBox>
                </Grid>
            </TabItem>
            <TabItem Header="Axes">
                <Grid Margin="8,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <GroupBox Grid.Column="0" Header="X axis" Padding="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <CheckBox
                                x:Name="ShowXAxisCheck"
                                Grid.Row="0"
                                Grid.Column="0"
                                Grid.ColumnSpan="2"
                                Margin="0,0,0,10"
                                Content="Show X axis" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center" Text="Title" />
                            <TextBox x:Name="XAxisLabelText" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" MinHeight="24" />
                            <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center" Text="Unit" />
                            <TextBox x:Name="XAxisUnitText" Grid.Row="2" Grid.Column="1" Margin="0,0,0,8" MinHeight="24" />
                            <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Center" Text="Precision" />
                            <TextBox x:Name="XAxisPrecisionText" Grid.Row="3" Grid.Column="1" MinHeight="24" />
                        </Grid>
                    </GroupBox>
                    <GroupBox Grid.Column="2" Header="Y axis" Padding="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <CheckBox
                                x:Name="ShowYAxisCheck"
                                Grid.Row="0"
                                Grid.Column="0"
                                Grid.ColumnSpan="2"
                                Margin="0,0,0,10"
                                Content="Show Y axis" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center" Text="Title" />
                            <TextBox x:Name="YAxisLabelText" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" MinHeight="24" />
                            <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center" Text="Unit" />
                            <TextBox x:Name="YAxisUnitText" Grid.Row="2" Grid.Column="1" Margin="0,0,0,8" MinHeight="24" />
                            <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Center" Text="Precision" />
                            <TextBox x:Name="YAxisPrecisionText" Grid.Row="3" Grid.Column="1" MinHeight="24" />
                        </Grid>
                    </GroupBox>
                </Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
