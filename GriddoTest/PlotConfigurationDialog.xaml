<Window
    x:Class="GriddoTest.PlotConfigurationDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Plot configuration"
    Width="420"
    MinHeight="360"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <GroupBox Header="Title" Margin="0,0,0,8" Padding="8">
                    <TextBox
                        x:Name="TitleText"
                        MinHeight="24"
                        TextWrapping="Wrap" />
                </GroupBox>
                <GroupBox Header="Label" Margin="0,0,0,8" Padding="8">
                    <TextBox
                        x:Name="LabelText"
                        MinHeight="24"
                        TextWrapping="Wrap"
                        ToolTip="Optional subtitle shown under the title" />
                </GroupBox>
                <GroupBox Header="X axis" Margin="0,0,0,8" Padding="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="0"
                            Margin="0,0,8,6"
                            VerticalAlignment="Center"
                            Text="Axis label" />
                        <TextBox
                            x:Name="XAxisLabelText"
                            Grid.Row="0"
                            Grid.Column="1"
                            Margin="0,0,0,6"
                            MinHeight="24" />
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="0"
                            Margin="0,0,8,6"
                            VerticalAlignment="Center"
                            Text="Minimum" />
                        <TextBox
                            x:Name="XMinText"
                            Grid.Row="1"
                            Grid.Column="1"
                            Margin="0,0,0,6"
                            MinHeight="24" />
                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="0"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            Text="Maximum" />
                        <TextBox
                            x:Name="XMaxText"
                            Grid.Row="2"
                            Grid.Column="1"
                            MinHeight="24" />
                    </Grid>
                </GroupBox>
                <GroupBox Header="Y axis" Padding="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="0"
                            Margin="0,0,8,6"
                            VerticalAlignment="Center"
                            Text="Axis label" />
                        <TextBox
                            x:Name="YAxisLabelText"
                            Grid.Row="0"
                            Grid.Column="1"
                            Margin="0,0,0,6"
                            MinHeight="24" />
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="0"
                            Margin="0,0,8,6"
                            VerticalAlignment="Center"
                            Text="Minimum" />
                        <TextBox
                            x:Name="YMinText"
                            Grid.Row="1"
                            Grid.Column="1"
                            Margin="0,0,0,6"
                            MinHeight="24" />
                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="0"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            Text="Maximum" />
                        <TextBox
                            x:Name="YMaxText"
                            Grid.Row="2"
                            Grid.Column="1"
                            MinHeight="24" />
                    </Grid>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>
        <StackPanel
            Grid.Row="1"
            Margin="0,12,0,0"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                Width="88"
                Margin="0,0,8,0"
                Click="Ok_Click"
                Content="OK"
                IsDefault="True" />
            <Button
                Width="88"
                Content="Cancel"
                IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
