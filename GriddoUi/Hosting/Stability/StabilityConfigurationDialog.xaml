<Window
    x:Class="GriddoUi.Hosting.Stability.StabilityConfigurationDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:grid="clr-namespace:Griddo.Grid;assembly=Griddo"
    Title="Stability field configurator"
    Width="1020"
    Height="640"
    MinWidth="800"
    MinHeight="520"
    WindowStartupLocation="CenterOwner">
    <DockPanel>
        <Border
            DockPanel.Dock="Bottom"
            Padding="10,8"
            Background="{DynamicResource AppControlBackgroundBrush}"
            BorderBrush="{DynamicResource AppControlBorderBrush}"
            BorderThickness="0,1,0,0">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="MoveUpButton" Width="72" Margin="0,0,8,0" Click="MoveUpButton_Click" Content="Up" />
                    <Button x:Name="MoveDownButton" Width="72" Margin="0,0,16,0" Click="MoveDownButton_Click" Content="Down" />
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Width="88" Margin="0,0,8,0" Click="ApplyButton_Click" Content="Apply" />
                    <Button Width="88" Margin="0,0,8,0" Click="OkButton_Click" Content="OK" IsDefault="True" />
                    <Button Width="88" Click="CancelButton_Click" Content="Cancel" IsCancel="True" />
                </StackPanel>
            </DockPanel>
        </Border>
        <TabControl x:Name="MainTabs" Margin="8" SelectionChanged="MainTabs_SelectionChanged">
            <TabItem Header="Fields">
                <grid:Griddo
                    x:Name="SeriesGrid"
                    Margin="8,6"
                    ShowFieldHeaderSelectionColoring="False"
                    ShowRecordHeaderSelectionColoring="False"
                    UniformRecordHeight="26" />
            </TabItem>
            <TabItem Header="General settings">
                <grid:Griddo
                    x:Name="GeneralGrid"
                    Margin="8,6"
                    ShowFieldHeaderSelectionColoring="False"
                    ShowRecordHeaderSelectionColoring="False"
                    UniformRecordHeight="26" />
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
