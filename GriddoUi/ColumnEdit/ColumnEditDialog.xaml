<Window
    x:Class="GriddoUi.ColumnEdit.GridConfigurator"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:grid="clr-namespace:Griddo.Grid;assembly=Griddo"
    Title="Grid configurator"
    Width="960"
    Height="620"
    WindowStartupLocation="CenterOwner"
    ShowInTaskbar="False">
    <DockPanel>
        <Border
            DockPanel.Dock="Bottom"
            Padding="10,8"
            Background="#FFF0F0F0"
            BorderBrush="#FFD0D0D0"
            BorderThickness="0,1,0,0">
            <StackPanel>
                <DockPanel LastChildFill="False">
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button
                            x:Name="MoveUpButton"
                            Width="72"
                            Margin="0,0,8,0"
                            Click="MoveUpButton_Click"
                            Content="Up" />
                        <Button
                            x:Name="MoveDownButton"
                            Width="72"
                            Margin="0,0,16,0"
                            Click="MoveDownButton_Click"
                            Content="Down" />
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button
                            Width="88"
                            Margin="0,0,8,0"
                            Click="ApplyButton_Click"
                            Content="Apply" />
                        <Button
                            Width="88"
                            Margin="0,0,8,0"
                            Click="OkButton_Click"
                            Content="OK"
                            IsDefault="True" />
                        <Button
                            Width="88"
                            Click="CancelButton_Click"
                            Content="Cancel"
                            IsCancel="True" />
                    </StackPanel>
                </DockPanel>
                <WrapPanel Margin="0,6,0,0" VerticalAlignment="Center">
                    <TextBlock Margin="0,0,8,0" VerticalAlignment="Center" Text="Fill rows:" />
                    <TextBox
                        x:Name="VisibleRowsBox"
                        Width="56"
                        Margin="0,0,10,0"
                        VerticalAlignment="Center"
                        Text="0" />
                    <TextBlock Margin="0,0,8,0" VerticalAlignment="Center" Text="Frozen columns:" />
                    <TextBox
                        x:Name="FrozenColumnsBox"
                        Width="56"
                        Margin="0,0,10,0"
                        VerticalAlignment="Center"
                        Text="0" />
                    <TextBlock Margin="0,0,8,0" VerticalAlignment="Center" Text="Frozen rows:" />
                    <TextBox
                        x:Name="FrozenRowsBox"
                        Width="56"
                        Margin="0,0,10,0"
                        VerticalAlignment="Center"
                        Text="0" />
                </WrapPanel>
                <WrapPanel Margin="0,4,0,0" VerticalAlignment="Center">
                    <CheckBox
                        x:Name="ImmediateCellEditBox"
                        Margin="0,0,14,0"
                        VerticalAlignment="Center"
                        Content="Immediate edit (Plot only)" />
                    <TextBlock Margin="0,0,8,0" VerticalAlignment="Center" Text="Show indicators:" />
                    <CheckBox
                        x:Name="ShowSortingIndicatorsBox"
                        Margin="0,0,14,0"
                        VerticalAlignment="Center"
                        Content="Sorting" />
                    <TextBlock Margin="0,0,8,0" VerticalAlignment="Center" Text="Show colors:" />
                    <CheckBox
                        x:Name="ShowSelectionColorBox"
                        Margin="0,0,10,0"
                        VerticalAlignment="Center"
                        Content="Selection" />
                    <CheckBox
                        x:Name="ShowRowSelectionColorBox"
                        Margin="0,0,10,0"
                        VerticalAlignment="Center"
                        Content="Row" />
                    <CheckBox
                        x:Name="ShowColSelectionColorBox"
                        Margin="0,0,14,0"
                        VerticalAlignment="Center"
                        Content="Col" />
                    <TextBlock Margin="0,0,8,0" VerticalAlignment="Center" Text="Show rects:" />
                    <CheckBox
                        x:Name="ShowCurrentCellRectBox"
                        Margin="0,0,10,0"
                        VerticalAlignment="Center"
                        Content="Current cell" />
                    <CheckBox
                        x:Name="ShowEditCellRectBox"
                        Margin="0,0,14,0"
                        VerticalAlignment="Center"
                        Content="Edit cell" />
                </WrapPanel>
            </StackPanel>
        </Border>
        <grid:Griddo
            x:Name="ColumnGrid"
            Margin="8"
            UniformRowHeight="26" />
    </DockPanel>
</Window>
